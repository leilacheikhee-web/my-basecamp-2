<div class="page form-page">
  <h1>Edit Thread</h1>
  <% if @error %>
    <div class="alert alert-error"><%= h(@error) %></div>
  <% end %>
  
  <form method="POST" action="/threads/<%= @thread['id'] %>">
    <div class="form-group">
      <label for="title">Thread Title *</label>
      <input type="text" id="title" name="title" value="<%= h(@thread['title']) %>" required class="form-input">
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" class="form-input" rows="6"><%= h(@thread['description'].to_s) %></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">Update Thread</button>
      <a href="/threads/<%= @thread['id'] %>" class="btn-secondary">Cancel</a>
    </div>
  </form>
</div>
