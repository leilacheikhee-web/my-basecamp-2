<div class="auth-page">
  <div class="auth-card">
    <h1>Welcome back</h1>
    <% if @error %>
      <div class="alert error"><%= h(@error) %></div>
    <% end %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" required autofocus placeholder="john@example.com">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit" class="btn-primary btn-full">Sign in</button>
    </form>
    <p class="auth-switch">New here? <a href="/register">Create account</a></p>
  </div>
</div>
