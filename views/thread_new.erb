<div class="page form-page">
  <h1>New Thread</h1>
  <% if @error %>
    <div class="alert alert-error"><%= h(@error) %></div>
  <% end %>
  
  <form method="POST" action="/projects/<%= @project['id'] %>/threads">
    <div class="form-group">
      <label for="title">Thread Title *</label>
      <input type="text" id="title" name="title" required class="form-input">
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" class="form-input" rows="6"></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">Create Thread</button>
      <a href="/projects/<%= @project['id'] %>" class="btn-secondary">Cancel</a>
    </div>
  </form>
</div>
