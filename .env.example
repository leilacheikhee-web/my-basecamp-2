# Local Development Environment Variables
# Copy this file to .env and update values as needed

# Port to run the app on (default: 8080)
PORT=8080

# Session secret for secure cookies (generate a random string for production)
SESSION_SECRET=your_secure_random_string_of_at_least_64_characters_1234567890

# Database Configuration
# For local development, comment out DATABASE_URL to use SQLite
# For production (Render), Render automatically injects DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/basecamp

# Rack environment
# Set to 'production' on Render, 'development' locally
RACK_ENV=development
